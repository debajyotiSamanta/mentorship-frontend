# Frontend Environment Variables

# Backend API URL (REQUIRED in production)
# For local development: http://localhost:5000/api
# For production: https://mentorship-backend-silk.vercel.app/api
VITE_API_URL=https://mentorship-backend-silk.vercel.app/api

# Pusher Configuration (Optional - For real-time features)
VITE_PUSHER_KEY=your_pusher_key
VITE_PUSHER_CLUSTER=your_pusher_cluster
